# JARVIS local configuration
# Copy this file to `.env` and replace every placeholder value below.

# Required: Anthropic API key for the assistant brain
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# Required: Fish Audio API key for voice output
FISH_API_KEY=YOUR_FISH_AUDIO_API_KEY_HERE

# Optional: Fish Audio voice model ID
# Default in server.py is the built-in JARVIS voice, but you can override it here.
FISH_VOICE_ID=YOUR_FISH_VOICE_ID_HERE

# Optional: Name JARVIS should use for you
USER_NAME=HARRY

# Optional: Honorific used by JARVIS
HONORIFIC=BOSS

# Optional: Comma-separated calendar account names or emails
# Leave as "auto" to let JARVIS discover calendars automatically.
CALENDAR_ACCOUNTS=auto

# Optional: Google OAuth credentials for Gmail/Google Calendar.
# If these are set, JARVIS will prefer Google APIs over Apple Mail/Calendar.
GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_OAUTH_CLIENT_SECRET
GOOGLE_REFRESH_TOKEN=YOUR_GOOGLE_OAUTH_REFRESH_TOKEN
GOOGLE_USER_EMAIL=you@gmail.com
GOOGLE_CALENDAR_IDS=primary
GOOGLE_TIMEZONE=Asia/Kolkata

# Optional: speed up spoken output. 1.0 = normal, 1.25 = faster.
FISH_SPEECH_SPEED=1.25
